{
  "name": "e-commerce",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --no-server-fast-refresh",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --no-server-fast-refresh",
    "dev:https": "cross-env NODE_OPTIONS=--no-deprecation next dev --experimental-https --no-server-fast-refresh",
    "devsafe:https": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --experimental-https --no-server-fast-refresh",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@payloadcms/admin-bar": "^3.81.0",
    "@payloadcms/db-postgres": "^3.81.0",
    "@payloadcms/db-sqlite": "^3.81.0",
    "@payloadcms/email-resend": "^3.81.0",
    "@payloadcms/kv-redis": "^3.81.0",
    "@payloadcms/live-preview-react": "^3.81.0",
    "@payloadcms/next": "^3.81.0",
    "@payloadcms/plugin-ecommerce": "^3.81.0",
    "@payloadcms/plugin-form-builder": "^3.81.0",
    "@payloadcms/plugin-mcp": "^3.81.0",
    "@payloadcms/plugin-multi-tenant": "^3.81.0",
    "@payloadcms/plugin-nested-docs": "^3.81.0",
    "@payloadcms/plugin-redirects": "^3.81.0",
    "@payloadcms/plugin-seo": "^3.81.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@payloadcms/sdk": "^3.81.0",
    "@payloadcms/storage-s3": "^3.81.0",
    "@payloadcms/ui": "^3.81.0",
    "@radix-ui/react-slot": "^1.2.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.0",
    "graphql": "^16.8.1",
    "lucide-react": "^0.511.0",
    "motion": "^12.38.0",
    "next": "16.2.2",
    "nuqs": "^2.8.9",
    "payload": "3.81.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "shadcn": "^4.1.2",
    "sharp": "0.32.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "thumbhash": "^0.1.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@payloadcms/typescript-plugin": "^3.81.0",
    "@tailwindcss/postcss": "^4.1.7",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.5.4",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.7",
    "tw-animate-css": "^1.3.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.18.20"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.29.1"
}
